<section class="hero">
  <div class="hero-inner hero-inner--single">
    <div class="hero-left">
      <div class="hero-eyebrow">Sales Intelligence Layer</div>
      <h1 class="hero-headline"><%= abVariant === 'b' ? 'Your pipeline, ranked by purchase intent.' : 'Know which accounts to prioritize — every morning.' %></h1>
      <p class="hero-sub">SourcemAI monitors funding events, hiring surges, and CRM activity — then delivers a ranked daily digest of your highest-intent accounts. No dashboards to dig through. No guesswork.</p>
    </div>
  </div>
</section>

<script>
(function () {
  var EXP = 'hero-headline';
  var vid = localStorage.getItem('polsia_vid') || null;

  function getVariant() {
    var stored = localStorage.getItem('ab_' + EXP);
    if (stored) return stored;
    var assigned = Math.random() < 0.5 ? 'a' : 'b';
    localStorage.setItem('ab_' + EXP, assigned);
    return assigned;
  }

  var variant = getVariant();
  var ctaClicked = false;

  // Track impression
  fetch('/api/ab-test/track', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ experiment: EXP, variant: variant, event: 'impression', visitor_id: vid }),
    keepalive: true
  });

  // Track CTA clicks to pricing cards
  document.querySelectorAll('.pricing-cta').forEach(function (el) {
    el.addEventListener('click', function () {
      if (!ctaClicked) {
        ctaClicked = true;
        fetch('/api/ab-test/track', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ experiment: EXP, variant: variant, event: 'cta_click', visitor_id: vid }),
          keepalive: true
        });
      }
    });
  });
})();
</script>

