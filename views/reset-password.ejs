<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset password — SourcemAI</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="/css/app.css">
  <style>
    :root {
      --accent: #D4A843;
      --accent-dim: #B8922E;
      --accent-glow: rgba(212, 168, 67, 0.12);
    }
    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(180deg, #FFFFFF 0%, #FDFDF8 60%, #f5f5f0 100%);
      font-family: 'DM Sans', sans-serif;
      padding: var(--space-lg);
    }
    .login-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: var(--space-2xl) var(--space-2xl);
      width: 100%;
      max-width: 420px;
      box-shadow: 0 8px 40px rgba(0,0,0,0.08);
    }
    .login-logo {
      font-family: 'Sora', sans-serif;
      font-weight: 800;
      font-size: 1.5rem;
      color: var(--fg);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: var(--space-xl);
    }
    .login-logo-img {
      height: 32px;
      width: auto;
    }
    .login-title {
      font-family: 'Sora', sans-serif;
      font-weight: 700;
      font-size: 1.5rem;
      color: var(--fg);
      margin-bottom: var(--space-xs);
    }
    .login-sub {
      font-size: 0.95rem;
      color: var(--fg-muted);
      margin-bottom: var(--space-xl);
      line-height: 1.6;
    }
    .form-group {
      margin-bottom: var(--space-lg);
    }
    label {
      display: block;
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--fg);
      margin-bottom: var(--space-xs);
    }
    input[type="password"] {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1.5px solid var(--border);
      border-radius: var(--radius-md);
      font-size: 1rem;
      font-family: inherit;
      color: var(--fg);
      background: var(--bg);
      transition: border-color 0.2s;
      box-sizing: border-box;
    }
    input[type="password"]:focus {
      outline: none;
      border-color: var(--accent);
    }
    .btn-submit {
      width: 100%;
      padding: 0.875rem 1.5rem;
      background: var(--accent);
      color: #1a2744;
      font-weight: 600;
      font-size: 1rem;
      border: none;
      border-radius: var(--radius-md);
      cursor: pointer;
      transition: background 0.2s;
      font-family: inherit;
    }
    .btn-submit:hover { background: var(--accent-dim); }
    .btn-submit:disabled { opacity: 0.6; cursor: default; }
    .error-banner {
      background: rgba(239, 68, 68, 0.06);
      border: 1px solid rgba(239, 68, 68, 0.2);
      border-radius: var(--radius-md);
      padding: var(--space-md) var(--space-lg);
      color: #dc2626;
      font-size: 0.9rem;
      margin-bottom: var(--space-lg);
    }
    .success-state {
      text-align: center;
      padding: var(--space-xl) 0;
    }
    .success-icon {
      width: 56px;
      height: 56px;
      background: var(--accent-glow);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto var(--space-lg);
    }
    .success-title {
      font-family: 'Sora', sans-serif;
      font-weight: 700;
      font-size: 1.25rem;
      color: var(--fg);
      margin-bottom: var(--space-sm);
    }
    .success-desc {
      font-size: 0.95rem;
      color: var(--fg-muted);
      margin-bottom: var(--space-xl);
      line-height: 1.6;
    }
    .resend-link {
      font-size: 0.875rem;
      color: var(--fg-muted);
    }
    .resend-link a {
      color: var(--accent-dim);
      text-decoration: none;
      font-weight: 500;
    }
    .resend-link a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="login-card">
    <a href="/" class="login-logo">
      <img src="https://pub-629428d185ca4960a0a73c850d32294b.r2.dev/company_160798/images/6ac4f552-fd8a-4c97-a90d-230e373fff98.png" class="login-logo-img" alt="SourcemAI">
      SourcemAI
    </a>

    <% if (sent) { %>
    <div class="success-state">
      <div class="success-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D4A843" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <div class="success-title">Your password is updated</div>
      <p class="success-desc">Your password is updated. You can now sign in.</p>
      <p class="resend-link"><a href="/auth/login">Go to sign in</a></p>
    </div>
    <% } else { %>
    <h1 class="login-title">Reset your password</h1>
    <p class="login-sub">Enter a new password for your SourcemAI account.</p>

    <% if (error) { %>
    <div class="error-banner"><%= error %></div>
    <% } %>

    <form id="reset-form" method="post" action="/auth/reset-password">
      <input type="hidden" name="token" value="<%= token %>">
      <div class="form-group">
        <label for="password">New password</label>
        <input type="password" id="password" name="password" placeholder="At least 8 characters" autocomplete="new-password" minlength="8" required autofocus>
      </div>
      <button type="submit" class="btn-submit" id="submit-btn">Reset password</button>
    </form>
    <% } %>
  </div>

  <script>
    const form = document.getElementById('reset-form');
    if (form) {
      form.addEventListener('submit', () => {
        const btn = document.getElementById('submit-btn');
        btn.disabled = true;
        btn.textContent = 'Resetting…';
      });
    }
  </script>
</body>
</html>
